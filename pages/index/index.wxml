<!--index.wxml-->
<wxs module="utils">
module.exports = {
  toHex: function(val) {
    var hex = val.toString(16).toUpperCase();
    if (hex.length === 1) {
      hex = '0' + hex;
    }
    return hex;
  }
}
</wxs>

<view class="container font-{{settings.fontSize}}">
  <!-- 自定义导航栏 -->
  <view class="custom-nav-bar" style="height: {{navBarHeight}}px;">
    <view class="nav-bar-title">W3B蓝牙遥控器</view>
  </view>
  
  <!-- 内容区域 -->
  <view class="content-wrapper">
    <!-- 顶部功能区 (20vh) -->
  <view class="top-section">
    <view class="top-left">
      <!-- 蓝牙状态和操作按钮组 -->
      <view class="status-and-buttons">
        <view class="status-row">
          <view class="status-dot {{isConnected ? 'connected' : (isSearching ? 'connecting' : 'disconnected')}}"></view>
          <text class="status-text">{{isConnected ? '已连接' : (isSearching ? '搜索中...' : '未连接')}}</text>
        </view>
        
        <view class="btn-group">
          <view class="glass-btn primary {{isSearching ? 'disabled' : ''}}" bindtap="startSearch" hover-class="btn-hover">搜索</view>
          <view class="glass-btn {{isConnected || !lastDeviceId ? 'disabled' : ''}}" bindtap="reconnectLast" hover-class="btn-hover">重连</view>
          <view class="glass-btn warning {{!isConnected ? 'disabled' : ''}}" bindtap="disconnectDevice" hover-class="btn-hover">断开</view>
        </view>
      </view>
    </view>

    <view class="top-right">
      <view class="glass-icon-btn" bindtap="toggleLogPanel" hover-class="btn-hover" wx:if="{{!isEditMode}}">LOG</view>
      <view class="glass-icon-btn" bindtap="toggleSettings" hover-class="btn-hover" wx:if="{{!isEditMode}}">⚙</view>
      <view class="glass-icon-btn" bindtap="toggleEditMode" hover-class="btn-hover" wx:if="{{!isEditMode}}">✎</view>
      
      <!-- Edit Mode Toolbar -->
      <view class="edit-toolbar" wx:if="{{isEditMode}}">
        <view class="glass-btn warning" bindtap="restoreDefaultLayout">重置</view>
        <view class="glass-btn primary" bindtap="saveLayout">保存</view>
      </view>
    </view>
  </view>

  <!-- 中间日志显示区 (40vh) -->
  <view class="middle-section">
    <!-- 日志容器 -->
    <view class="log-container glass-panel" bindtap="toggleLogPanel" hover-class="panel-hover">
      <block wx:if="{{logList.length > 0}}">
        <view class="log-line highlight">
          <text class="log-time">{{logList[0].time}}</text>
          <text class="log-hex">{{logList[0].hex}}</text>
        </view>
      </block>
      <view class="log-empty" wx:else>
        <text>暂无数据日志</text>
      </view>
    </view>

    <!-- 设备列表浮层 (保持在中间区域上方，作为临时覆盖) -->
    <view class="device-list-overlay glass-panel" wx:if="{{deviceList.length > 0}}">
      <view class="overlay-header">
        <text class="overlay-title">发现设备 ({{deviceList.length}})</text>
        <view class="close-btn" catchtap="closeDeviceList">✕</view>
      </view>
      <scroll-view class="device-scroll" scroll-y="true">
        <view 
          class="device-item" 
          wx:for="{{deviceList}}" 
          wx:key="deviceId" 
          bindtap="connectDevice" 
          data-deviceid="{{item.deviceId}}"
          hover-class="item-hover"
        >
          <text class="device-name">{{item.name}}</text>
          <text class="device-rssi">{{item.RSSI}}dBm</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 底部操控区 (40vh) -->
  <view class="bottom-section">
    <!-- 左摇杆区 (33vw) -->
    <view class="control-zone joystick-zone left-zone {{isEditMode ? 'editing-zone' : ''}}"
          style="transform: translate({{layout.leftJoystick.x}}px, {{layout.leftJoystick.y}}px) scale({{layout.leftJoystick.scale}});"
          data-key="leftJoystick"
          catchtouchstart="{{isEditMode ? 'onLayoutTouchStart' : ''}}"
          catchtouchmove="{{isEditMode ? 'onLayoutTouchMove' : ''}}"
          catchtouchend="{{isEditMode ? 'onLayoutTouchEnd' : ''}}">
      
      <!-- Edit Overlay Mask -->
      <view class="edit-mask" wx:if="{{isEditMode}}"></view>

      <view class="joystick-value">
        <text>L: {{leftSpeed}}</text>
      </view>
      <view 
        class="joystick-area"
        id="leftPad"
        data-side="left"
        bindtouchstart="{{!isEditMode ? 'onJoystickStart' : ''}}"
        bindtouchmove="{{!isEditMode ? 'onJoystickMove' : ''}}"
        bindtouchend="{{!isEditMode ? 'onJoystickEnd' : ''}}"
        bindtouchcancel="{{!isEditMode ? 'onJoystickEnd' : ''}}"
      >
        <view class="joystick-base">
          <view class="joystick-stick" style="transform: translate({{leftStick.x}}px, {{leftStick.y}}px);"></view>
        </view>
      </view>
    </view>

    <!-- 中间按钮区 (34vw) -->
    <view class="control-zone buttons-zone {{isEditMode ? 'editing-zone' : ''}}"
          style="transform: translate({{layout.buttons.x}}px, {{layout.buttons.y}}px) scale({{layout.buttons.scale}});"
          data-key="buttons"
          catchtouchstart="{{isEditMode ? 'onLayoutTouchStart' : ''}}"
          catchtouchmove="{{isEditMode ? 'onLayoutTouchMove' : ''}}"
          catchtouchend="{{isEditMode ? 'onLayoutTouchEnd' : ''}}">
      
      <view class="edit-mask" wx:if="{{isEditMode}}"></view>

      <view class="btn-grid">
        <view class="game-btn red {{btnRed?'active':''}}" data-color="red" bindtouchstart="{{!isEditMode ? 'onButtonTouchStart' : ''}}" bindtouchend="{{!isEditMode ? 'onButtonTouchEnd' : ''}}">A</view>
        <view class="game-btn blue {{btnBlue?'active':''}}" data-color="blue" bindtouchstart="{{!isEditMode ? 'onButtonTouchStart' : ''}}" bindtouchend="{{!isEditMode ? 'onButtonTouchEnd' : ''}}">B</view>
        <view class="game-btn green {{btnGreen?'active':''}}" data-color="green" bindtouchstart="{{!isEditMode ? 'onButtonTouchStart' : ''}}" bindtouchend="{{!isEditMode ? 'onButtonTouchEnd' : ''}}">C</view>
        <view class="game-btn yellow {{btnYellow?'active':''}}" data-color="yellow" bindtouchstart="{{!isEditMode ? 'onButtonTouchStart' : ''}}" bindtouchend="{{!isEditMode ? 'onButtonTouchEnd' : ''}}">D</view>
      </view>
    </view>

    <!-- 右摇杆区 (33vw) -->
    <view class="control-zone joystick-zone right-zone {{isEditMode ? 'editing-zone' : ''}}"
          style="transform: translate({{layout.rightJoystick.x}}px, {{layout.rightJoystick.y}}px) scale({{layout.rightJoystick.scale}});"
          data-key="rightJoystick"
          catchtouchstart="{{isEditMode ? 'onLayoutTouchStart' : ''}}"
          catchtouchmove="{{isEditMode ? 'onLayoutTouchMove' : ''}}"
          catchtouchend="{{isEditMode ? 'onLayoutTouchEnd' : ''}}">
      
      <view class="edit-mask" wx:if="{{isEditMode}}"></view>

      <view class="joystick-value">
        <text>R: {{rightSpeed}}</text>
      </view>
      <view 
        class="joystick-area"
        id="rightPad"
        data-side="right"
        bindtouchstart="{{!isEditMode ? 'onJoystickStart' : ''}}"
        bindtouchmove="{{!isEditMode ? 'onJoystickMove' : ''}}"
        bindtouchend="{{!isEditMode ? 'onJoystickEnd' : ''}}"
        bindtouchcancel="{{!isEditMode ? 'onJoystickEnd' : ''}}"
      >
        <view class="joystick-base">
          <view class="joystick-stick" style="transform: translate({{rightStick.x}}px, {{rightStick.y}}px);"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 全屏日志悬浮窗 -->
  <view class="full-overlay glass-background" wx:if="{{showLogPanel}}" catchtap="closeLogPanel">
    <view class="overlay-panel glass-panel" catchtap="stopProp">
      <view class="panel-header">
        <text class="panel-title">数据包日志</text>
        <view class="header-btns">
          <view class="header-btn" catchtap="clearLog">清空</view>
          <view class="header-btn close" catchtap="closeLogPanel">✕</view>
        </view>
      </view>
      <view class="log-legend">
        <text class="legend-item">L:左电机</text>
        <text class="legend-item">R:右电机</text>
        <text class="legend-item">A/B/C/D:按钮</text>
        <text class="legend-item">X:校验</text>
        <text class="legend-item">T:尾标</text>
      </view>
      <scroll-view class="panel-content" scroll-y="true">
        <view class="log-item" wx:for="{{logList}}" wx:key="index">
          <text class="item-time">[{{item.time}}]</text>
          <text class="item-hex">{{item.hex}}</text>
        </view>
        <view class="empty-tip" wx:if="{{logList.length === 0}}">暂无日志</view>
      </scroll-view>
    </view>
  </view>

  </view>
  
  <!-- 设置悬浮窗 -->
  <view class="full-overlay glass-background" wx:if="{{showSettings}}" catchtap="closeSettings">
    <view class="overlay-panel ios-settings-panel" catchtap="stopProp">
      <!-- 顶部导航栏 -->
      <view class="ios-nav-bar">
        <view class="nav-btn cancel" catchtap="closeSettings">取消</view>
        <text class="nav-title">设置</text>
        <view class="nav-btn save" catchtap="saveSettings">保存</view>
      </view>

      <!-- 设置内容区 -->
      <scroll-view class="ios-content" scroll-y="true">
        <!-- 第一组：通信参数 -->
        <view class="ios-group-title">通信参数</view>
        <view class="ios-group">
          <view class="ios-cell">
            <text class="cell-label">发送模式</text>
            <view class="segment-control">
              <view class="segment-item {{tempSettings.sendMode==='text'?'active':''}}" data-field="sendMode" data-value="text" catchtap="onModeChange">文本模式</view>
              <view class="segment-item {{tempSettings.sendMode==='binary'?'active':''}}" data-field="sendMode" data-value="binary" catchtap="onModeChange">二进制模式</view>
            </view>
          </view>
          <view class="ios-cell last">
            <text class="cell-label">发送间隔(ms)</text>
            <input class="cell-input" type="text" value="{{tempSettings.sendInterval}}" data-field="sendInterval" bindtap="showCustomKeyboard" readonly/>
          </view>
        </view>

        <!-- 第二组：界面显示 -->
        <view class="ios-group-title">界面显示</view>
        <view class="ios-group">
          <view class="ios-cell">
            <text class="cell-label">自动清空日志</text>
            <switch checked="{{tempSettings.autoClearLog}}" data-field="autoClearLog" bindchange="onSettingChange" color="#34C759"/>
          </view>
          <view class="ios-cell last">
            <text class="cell-label">全局字号</text>
            <view class="segment-control">
              <view class="segment-item {{tempSettings.fontSize==='small'?'active':''}}" data-size="small" catchtap="setFontSize">小</view>
              <view class="segment-item {{tempSettings.fontSize==='medium'?'active':''}}" data-size="medium" catchtap="setFontSize">中</view>
              <view class="segment-item {{tempSettings.fontSize==='large'?'active':''}}" data-size="large" catchtap="setFontSize">大</view>
            </view>
          </view>
        </view>

        <!-- 第三组：关于 -->
        <view class="ios-group-title">关于</view>
        <view class="ios-group">
          <view class="ios-cell last">
            <text class="cell-label">W3B蓝牙遥控器 v1.0</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
  
  <!-- 自定义数字键盘 -->
  <view class="custom-keyboard-overlay" wx:if="{{showCustomKeyboard}}" catchtap="hideCustomKeyboard">
    <view class="custom-keyboard" catchtap="stopProp">
      <!-- 键盘标题 -->
      <view class="keyboard-header">
        <text class="keyboard-title">{{keyboardTitle}}</text>
        <view class="keyboard-close" catchtap="hideCustomKeyboard">×</view>
      </view>
      <!-- 输入显示 -->
      <view class="keyboard-input">
        <input class="keyboard-input-field" type="text" value="{{currentInputValue}}" placeholder="0" readonly/>
      </view>
      <!-- 键盘按键 -->
      <view class="keyboard-buttons">
        <!-- 第一行 -->
        <view class="keyboard-row">
          <view class="keyboard-btn number" catchtap="onKeyboardNumberTap" data-number="1">1</view>
          <view class="keyboard-btn number" catchtap="onKeyboardNumberTap" data-number="2">2</view>
          <view class="keyboard-btn number" catchtap="onKeyboardNumberTap" data-number="3">3</view>
        </view>
        <!-- 第二行 -->
        <view class="keyboard-row">
          <view class="keyboard-btn number" catchtap="onKeyboardNumberTap" data-number="4">4</view>
          <view class="keyboard-btn number" catchtap="onKeyboardNumberTap" data-number="5">5</view>
          <view class="keyboard-btn number" catchtap="onKeyboardNumberTap" data-number="6">6</view>
        </view>
        <!-- 第三行 -->
        <view class="keyboard-row">
          <view class="keyboard-btn number" catchtap="onKeyboardNumberTap" data-number="7">7</view>
          <view class="keyboard-btn number" catchtap="onKeyboardNumberTap" data-number="8">8</view>
          <view class="keyboard-btn number" catchtap="onKeyboardNumberTap" data-number="9">9</view>
        </view>
        <!-- 第四行 -->
        <view class="keyboard-row">
          <view class="keyboard-btn clear" catchtap="onKeyboardClearTap">清空</view>
          <view class="keyboard-btn number" catchtap="onKeyboardNumberTap" data-number="0">0</view>
          <view class="keyboard-btn delete" catchtap="onKeyboardDeleteTap">删除</view>
        </view>
        <!-- 确认按钮 -->
        <view class="keyboard-row">
          <view class="keyboard-btn confirm" catchtap="onKeyboardConfirmTap" style="width: 100%;">确认</view>
        </view>
      </view>
    </view>
  </view>
</view>
