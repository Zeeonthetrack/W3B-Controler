<!--index.wxml-->
<view class="container {{fontSizeMode}}">
  <view class="top-settings-area">
    <view class="settings-left">
      <view class="info-row"><text class="status-text">状态: {{connectStatus}}</text></view>
      <view class="control-row">
         <button class="mini-btn primary" bindtap="startSearch" disabled="{{isSearching}}">搜索</button>
         <button class="mini-btn normal" bindtap="reconnectLast" disabled="{{!lastDeviceId || isConnected}}">重连</button>
         <button class="mini-btn warn" bindtap="disconnectDevice" disabled="{{!isConnected}}">断开</button>
      </view>
      <view class="switch-row">
        <text class="label-text">自动清空日志</text>
        <switch checked="{{settings.autoClearLog}}" bindchange="toggleAutoClear" color="#2b6fff" class="mini-switch"/>
      </view>
    </view>
    <view class="settings-right">
       <view class="font-row">
          <view class="font-btn {{fontSizeMode === 'mode-s' ? 'active' : ''}}" catchtap="setFontSize" data-mode="mode-s">A-</view>
           <view class="font-btn {{fontSizeMode === 'mode-m' ? 'active' : ''}}" catchtap="setFontSize" data-mode="mode-m">A</view>
           <view class="font-btn {{fontSizeMode === 'mode-l' ? 'active' : ''}}" catchtap="setFontSize" data-mode="mode-l">A+</view>
       </view>
       <view class="log-btn-wrapper">
          <button class="log-btn" catchtap="toggleLogs">LOG</button>
       </view>
       <view class="settings-icon-wrapper" bindtap="toggleSettings">
          <text class="gear-icon">设置</text>
       </view>
    </view>
  </view>

  <scroll-view scroll-y class="device-list-float" wx:if="{{deviceList.length > 0}}">
    <view wx:for="{{deviceList}}" wx:key="deviceId" bindtap="connectDevice" data-deviceid="{{item.deviceId}}" class="device-item">
      {{item.name}} <text class="rssi">{{item.RSSI}}</text>
    </view>
  </scroll-view>

  <view class="middle-display-area">
    <view class="grid-bg"></view>
    <text class="hint-text">按住左下角/右下角区域激活摇杆</text>
  </view>

  <view class="bottom-operation-area">
    <view class="joystick-zone left-zone" data-side="left" catchtouchstart="onJoystickStart" catchtouchmove="onJoystickMove" catchtouchend="onJoystickEnd" catchtouchcancel="onJoystickEnd">
    </view>
    <view class="buttons-zone">
      <view class="btn-matrix">
         <view class="c-btn red {{btnRed?'active':''}}" data-color="red" catchtouchstart="onButtonTouchStart" catchtouchend="onButtonTouchEnd">A</view>
         <view class="c-btn blue {{btnBlue?'active':''}}" data-color="blue" catchtouchstart="onButtonTouchStart" catchtouchend="onButtonTouchEnd">B</view>
         <view class="c-btn green {{btnGreen?'active':''}}" data-color="green" catchtouchstart="onButtonTouchStart" catchtouchend="onButtonTouchEnd">C</view>
         <view class="c-btn yellow {{btnYellow?'active':''}}" data-color="yellow" catchtouchstart="onButtonTouchStart" catchtouchend="onButtonTouchEnd">D</view>
      </view>
    </view>
    <view class="joystick-zone right-zone" data-side="right" catchtouchstart="onJoystickStart" catchtouchmove="onJoystickMove" catchtouchend="onJoystickEnd" catchtouchcancel="onJoystickEnd">
    </view>
  </view>

  <view class="log-overlay" wx:if="{{showLogs}}">
     <view class="log-header">
       <text>通信日志</text>
       <view class="close-log" catchtap="toggleLogs">✕</view>
     </view>
     <scroll-view scroll-y class="log-scroll">
       <view wx:for="{{logList}}" wx:key="index" class="log-item">
         <text class="log-time">{{item.time}}</text>
         <text class="log-hex">{{item.hex}}</text>
       </view>
     </scroll-view>
  </view>

  <view class="joystick-float {{leftVis ? 'visible' : ''}}" style="left: {{leftPos.left}}px; top: {{leftPos.top}}px;">
    <view class="stick-outer">
       <view class="stick-inner" style="transform: translate({{leftStick.x}}px, {{leftStick.y}}px)"></view>
    </view>
  </view>

  <view class="joystick-float {{rightVis ? 'visible' : ''}}" style="left: {{rightPos.left}}px; top: {{rightPos.top}}px;">
    <view class="stick-outer">
       <view class="stick-inner" style="transform: translate({{rightStick.x}}px, {{rightStick.y}}px)"></view>
    </view>
  </view>
</view>
