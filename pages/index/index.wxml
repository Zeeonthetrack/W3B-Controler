<!--index.wxml-->
<wxs module="utils">
module.exports = {
  toHex: function(val) {
    var hex = val.toString(16).toUpperCase();
    if (hex.length === 1) {
      hex = '0' + hex;
    }
    return hex;
  }
}
</wxs>

<view class="container">
  <!-- 顶部功能区 (20vh) -->
  <view class="top-section">
    <view class="top-left">
      <!-- 蓝牙状态 -->
      <view class="status-row">
        <view class="status-dot {{isConnected ? 'connected' : (isSearching ? 'connecting' : 'disconnected')}}"></view>
        <text class="status-text">{{isConnected ? '已连接' : (isSearching ? '搜索中...' : '未连接')}}</text>
      </view>
      
      <!-- 操作按钮组 -->
      <view class="control-row">
        <view class="btn-group">
          <view class="glass-btn primary {{isSearching ? 'disabled' : ''}}" bindtap="startSearch" hover-class="btn-hover">搜索</view>
          <view class="glass-btn {{isConnected || !lastDeviceId ? 'disabled' : ''}}" bindtap="reconnectLast" hover-class="btn-hover">重连</view>
          <view class="glass-btn warning {{!isConnected ? 'disabled' : ''}}" bindtap="disconnectDevice" hover-class="btn-hover">断开</view>
        </view>
      </view>

      <!-- 自动清空日志开关 -->
      <view class="switch-row">
        <switch checked="{{settings.autoClearLog}}" bindchange="toggleAutoClear" color="#34C759" scale="0.7"/>
        <text class="switch-label">自动清空日志</text>
      </view>
    </view>

    <view class="top-right">
      <view class="glass-icon-btn" bindtap="toggleLogPanel" hover-class="btn-hover">LOG</view>
      <view class="glass-icon-btn" bindtap="toggleSettings" hover-class="btn-hover">⚙</view>
    </view>
  </view>

  <!-- 中间日志显示区 (40vh) -->
  <view class="middle-section">
    <!-- 日志容器 -->
    <view class="log-container glass-panel" bindtap="toggleLogPanel" hover-class="panel-hover">
      <block wx:if="{{logList.length > 0}}">
        <view class="log-line {{index === 0 ? 'highlight' : ''}}" wx:for="{{logList}}" wx:key="index" wx:if="{{index < 3}}">
          <text class="log-time">{{item.time}}</text>
          <text class="log-hex">{{item.hex}}</text>
        </view>
      </block>
      <view class="log-empty" wx:else>
        <text>暂无数据日志</text>
      </view>
    </view>

    <!-- 设备列表浮层 (保持在中间区域上方，作为临时覆盖) -->
    <view class="device-list-overlay glass-panel" wx:if="{{deviceList.length > 0}}">
      <view class="overlay-header">
        <text class="overlay-title">发现设备 ({{deviceList.length}})</text>
        <view class="close-btn" catchtap="stopSearch">✕</view>
      </view>
      <scroll-view class="device-scroll" scroll-y="true">
        <view 
          class="device-item" 
          wx:for="{{deviceList}}" 
          wx:key="deviceId" 
          bindtap="connectDevice" 
          data-deviceid="{{item.deviceId}}"
          hover-class="item-hover"
        >
          <text class="device-name">{{item.name}}</text>
          <text class="device-rssi">{{item.RSSI}}dBm</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 底部操控区 (40vh) -->
  <view class="bottom-section">
    <!-- 左摇杆区 (33vw) -->
    <view class="control-zone joystick-zone left-zone">
      <view class="joystick-value">
        <text>L: {{leftSpeed}}</text>
      </view>
      <view 
        class="joystick-area"
        id="leftPad"
        data-side="left"
        bindtouchstart="onJoystickStart"
        bindtouchmove="onJoystickMove"
        bindtouchend="onJoystickEnd"
        bindtouchcancel="onJoystickEnd"
      >
        <view class="joystick-base">
          <view class="joystick-stick" style="transform: translate({{leftStick.x}}px, {{leftStick.y}}px);"></view>
        </view>
      </view>
    </view>

    <!-- 中间按钮区 (34vw) -->
    <view class="control-zone buttons-zone">
      <view class="btn-grid">
        <view class="game-btn red {{btnRed?'active':''}}" data-color="red" bindtouchstart="onButtonTouchStart" bindtouchend="onButtonTouchEnd">A</view>
        <view class="game-btn blue {{btnBlue?'active':''}}" data-color="blue" bindtouchstart="onButtonTouchStart" bindtouchend="onButtonTouchEnd">B</view>
        <view class="game-btn green {{btnGreen?'active':''}}" data-color="green" bindtouchstart="onButtonTouchStart" bindtouchend="onButtonTouchEnd">C</view>
        <view class="game-btn yellow {{btnYellow?'active':''}}" data-color="yellow" bindtouchstart="onButtonTouchStart" bindtouchend="onButtonTouchEnd">D</view>
      </view>
    </view>

    <!-- 右摇杆区 (33vw) -->
    <view class="control-zone joystick-zone right-zone">
      <view class="joystick-value">
        <text>R: {{rightSpeed}}</text>
      </view>
      <view 
        class="joystick-area"
        id="rightPad"
        data-side="right"
        bindtouchstart="onJoystickStart"
        bindtouchmove="onJoystickMove"
        bindtouchend="onJoystickEnd"
        bindtouchcancel="onJoystickEnd"
      >
        <view class="joystick-base">
          <view class="joystick-stick" style="transform: translate({{rightStick.x}}px, {{rightStick.y}}px);"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 全屏日志悬浮窗 -->
  <view class="full-overlay glass-background" wx:if="{{showLogPanel}}" catchtap="closeLogPanel">
    <view class="overlay-panel glass-panel" catchtap="stopProp">
      <view class="panel-header">
        <text class="panel-title">数据包日志</text>
        <view class="header-btns">
          <view class="header-btn" catchtap="clearLog">清空</view>
          <view class="header-btn close" catchtap="closeLogPanel">✕</view>
        </view>
      </view>
      <scroll-view class="panel-content" scroll-y="true">
        <view class="log-item" wx:for="{{logList}}" wx:key="index">
          <text class="item-time">[{{item.time}}]</text>
          <text class="item-hex">{{item.hex}}</text>
        </view>
        <view class="empty-tip" wx:if="{{logList.length === 0}}">暂无日志</view>
      </scroll-view>
    </view>
  </view>

  <!-- 设置悬浮窗 -->
  <view class="full-overlay glass-background" wx:if="{{showSettings}}" catchtap="closeSettings">
    <view class="overlay-panel glass-panel" catchtap="stopProp">
      <view class="panel-header">
        <text class="panel-title">设置</text>
        <view class="header-btn close" catchtap="closeSettings">✕</view>
      </view>
      <view class="panel-content settings-list">
        <view class="setting-item">
          <text class="setting-label">过滤设备名称</text>
          <input class="setting-input glass-input" value="{{filterDeviceName}}" bindinput="onFilterInput" placeholder="请输入"/>
        </view>
        <view class="setting-item">
          <text class="setting-label">自动重连</text>
          <switch checked="{{settings.autoReconnect}}" bindchange="toggleAutoReconnect" color="#34C759"/>
        </view>
        <view class="setting-item">
          <text class="setting-label">自动清空日志</text>
          <switch checked="{{settings.autoClearLog}}" bindchange="toggleAutoClear" color="#34C759"/>
        </view>
      </view>
    </view>
  </view>
</view>
