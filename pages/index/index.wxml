<!--index.wxml-->
<view class="container {{fontSizeMode}}">
  
  <!-- === Layer 1: Touch Interaction Zones (Z-Index 1, Transparent) === -->
  <view class="touch-zones">
    <view 
      class="zone left-zone" 
      data-side="left"
      catchtouchstart="onJoystickStart"
      catchtouchmove="onJoystickMove"
      catchtouchend="onJoystickEnd"
      catchtouchcancel="onJoystickEnd"
    ></view>
    <view 
      class="zone right-zone" 
      data-side="right"
      catchtouchstart="onJoystickStart"
      catchtouchmove="onJoystickMove"
      catchtouchend="onJoystickEnd"
      catchtouchcancel="onJoystickEnd"
    ></view>
  </view>

  <!-- === Layer 2: Floating Joysticks (Z-Index 5, Visible when active) === -->
  <!-- Left Joystick -->
  <view 
    class="joystick-float {{leftVis ? 'visible' : ''}}" 
    style="left: {{leftPos.left}}px; top: {{leftPos.top}}px;"
    >
      <view class="joystick-base">
        <view class="joystick-stick {{leftVis ? 'active' : ''}}" style="transform: translate({{leftStick.x}}px, {{leftStick.y}}px);"></view>
      </view>
      <!-- Optional: Values following joystick? Or keep them top? -->
  </view>
  
  <!-- Right Joystick -->
  <view 
    class="joystick-float {{rightVis ? 'visible' : ''}}" 
    style="left: {{rightPos.left}}px; top: {{rightPos.top}}px;"
    >
      <view class="joystick-base">
        <view class="joystick-stick {{rightVis ? 'active' : ''}}" style="transform: translate({{rightStick.x}}px, {{rightStick.y}}px);"></view>
      </view>
  </view>

  <!-- === Layer 3: UI & Controls (Z-Index 10, Pointer Events for Buttons) === -->
  <view class="ui-layer">
    
    <!-- Top Status Bar (Minimally Obtrusive) -->
    <view class="top-bar">
      <view class="status-text">蓝牙: {{connectStatus}} | L:{{leftSpeed}} R:{{rightSpeed}}</view>
      <view class="top-actions">
        <!-- Log Toggle -->
        <view class="icon-btn log-btn" catchtap="toggleLogs">LOG</view>
        <!-- Settings Toggle -->
        <view class="icon-btn settings-btn" catchtap="toggleSettings">⚙</view>
      </view>
    </view>

    <!-- Bottom Center Controls -->
    <view class="center-dock">
       <view class="action-btn red {{btnRed?'active':''}}" data-color="red" bindtouchstart="onButtonTouchStart" bindtouchend="onButtonTouchEnd">A</view>
       <view class="action-btn blue {{btnBlue?'active':''}}" data-color="blue" bindtouchstart="onButtonTouchStart" bindtouchend="onButtonTouchEnd">B</view>
       <view class="action-btn green {{btnGreen?'active':''}}" data-color="green" bindtouchstart="onButtonTouchStart" bindtouchend="onButtonTouchEnd">C</view>
       <view class="action-btn yellow {{btnYellow?'active':''}}" data-color="yellow" bindtouchstart="onButtonTouchStart" bindtouchend="onButtonTouchEnd">D</view>
    </view>
  </view>

  <!-- === Layer 4: Popups (Z-Index 20+) === -->
  
  <!-- Log Panel (Slide in from Right) -->
  <view class="log-overlay {{showLogs ? 'show' : ''}}" bindtap="toggleLogs">
    <view class="log-panel" catchtap="stopProp">
      <view class="log-header">
        <text>数据包日志</text>
        <view class="log-actions">
          <text bindtap="clearLog">清空</text>
          <text bindtap="toggleLogs" class="close">X</text>
        </view>
      </view>
      <scroll-view class="log-scroll" scroll-y="true">
        <view class="log-item" wx:for="{{logList}}" wx:key="index">
          <text class="time">{{item.time}}</text>
          <text class="hex">{{item.hex}}</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- Settings Modal (Centered) -->
  <view class="modal-overlay" wx:if="{{showSettings}}" bindtap="closeSettings" catchtouchmove="stopProp">
    <view class="modal-content" catchtap="stopProp">
      <view class="modal-header">设置</view>
      
      <view class="setting-group">
        <view class="setting-row">
            <text>搜索蓝牙</text>
            <button size="mini" type="primary" bindtap="startSearch" disabled="{{isSearching}}">搜索</button>
        </view>
        <view class="device-list-mini" wx:if="{{deviceList.length > 0}}">
            <view wx:for="{{deviceList}}" wx:key="deviceId" bindtap="connectDevice" data-deviceid="{{item.deviceId}}" class="mini-device">
                {{item.name}}
            </view>
        </view>
        <view class="setting-row">
            <text>断开连接</text>
            <button size="mini" type="warn" bindtap="disconnectDevice" disabled="{{!isConnected}}">断开</button>
        </view>
      </view>

      <view class="setting-item">
        <text class="setting-label">自动清空日志</text>
        <switch checked="{{settings.autoClearLog}}" bindchange="toggleAutoClear" color="#2b6fff" style="transform: scale(0.7);"/>
      </view>
      
      <view class="setting-item">
        <text class="setting-label">全局字号</text>
        <view class="font-size-controls">
          <view class="font-btn {{fontSizeMode === 'mode-s' ? 'active' : ''}}" catchtap="setFontSize" data-mode="mode-s">小</view>
          <view class="font-btn {{fontSizeMode === 'mode-m' ? 'active' : ''}}" catchtap="setFontSize" data-mode="mode-m">中</view>
          <view class="font-btn {{fontSizeMode === 'mode-l' ? 'active' : ''}}" catchtap="setFontSize" data-mode="mode-l">大</view>
        </view>
      </view>
    </view>
  </view>

</view>
