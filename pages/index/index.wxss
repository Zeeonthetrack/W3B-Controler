/** index.wxss **/
page {
  background-color: #0d0d0d;
  color: #fff;
  height: 100vh;
  width: 100vw;
  overflow: hidden;
  font-family: -apple-system, sans-serif;
  box-sizing: border-box;
}

.container {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100%;
}

/* Top: 25vh */
.top-settings-area {
  height: 25vh;
  width: 100%;
  box-sizing: border-box;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  display: flex;
  background: #151515;
  z-index: 10;
}

/* Middle: 50vh */
.middle-display-area {
  height: 50vh;
  width: 100%;
  position: relative;
  box-sizing: border-box;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* Bottom: 25vh */
.bottom-operation-area {
  height: 25vh;
  width: 100%;
  display: flex;
  box-sizing: border-box;
  position: relative;
}

/* Settings Internal */
.settings-left, .settings-right {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 0 2vw;
  gap: 2vw;
  height: 100%;
}

.settings-left { justify-content: flex-start; flex-wrap: wrap; }
.settings-right { justify-content: flex-end; flex-wrap: wrap; }

.status-text { font-size: 2vh; font-weight: bold; color: #00e5ff; white-space: nowrap; }
.mini-btn { font-size: 1.6vh !important; padding: 0 1.5vh !important; height: 4vh; line-height: 4vh; margin: 0 !important; min-width: auto !important; border-radius: 4px; }
.mini-btn.primary { background: #07c160; color: #fff; }
.mini-btn.warn { background: #fa5151; color: #fff; }
.mini-btn.normal { background: #444; color: #fff; }
.mini-btn[disabled] { opacity: 0.3; background: #222 !important; color: #666 !important; }
.control-row { display: flex; gap: 1vw; }
.switch-row { display: flex; align-items: center; gap: 1vh; }
.label-text { font-size: 1.8vh; color: #aaa; white-space: nowrap; }

.font-row { display: flex; background: rgba(255,255,255,0.1); border-radius: 4px; overflow: hidden; margin-right: 1vw; }
.font-btn { padding: 0.8vh 1.5vh; font-size: 1.6vh; color: #aaa; cursor: pointer; }
.font-btn.active { background: #2b6fff; color: #fff; }

.log-btn-wrapper { margin-right: 1vw; }
.log-btn { font-size: 1.6vh; height: 4vh; line-height: 4vh; background: rgba(255,255,255,0.15); color: #fff; border: none; padding: 0 1.5vh; }
.settings-icon-wrapper { padding: 1vh; cursor: pointer; }
.gear-icon { font-size: 3vh; }

/* Middle */
.grid-bg {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background-image: 
    linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
  background-size: 4vh 4vh;
  z-index: 0;
}
.hint-text { z-index: 1; color: #666; font-size: 2vh; }

/* Bottom Zones */
.joystick-zone {
  height: 100%;
  box-sizing: border-box;
  border: 1px dashed rgba(255, 255, 255, 0.3);
  position: relative;
}
.left-zone { width: 35vw; }
.right-zone { width: 35vw; }
.buttons-zone { width: 30vw; display: flex; justify-content: center; align-items: center; }

.btn-matrix {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  gap: 1.5vh;
}
.c-btn {
  width: 7vh; height: 7vh; border-radius: 50%;
  display: flex; justify-content: center; align-items: center;
  font-weight: bold; font-size: 2.2vh;
  box-shadow: 0 4px 10px rgba(0,0,0,0.5);
  transition: transform 0.1s;
}
.c-btn:active, .c-btn.active { transform: scale(0.9); filter: brightness(1.2); }
.red { background: #ff4444; border: 2px solid #cc0000; }
.blue { background: #4444ff; border: 2px solid #0000cc; }
.green { background: #44ff44; border: 2px solid #00cc00; color: #000; }
.yellow { background: #ffff44; border: 2px solid #cccc00; color: #000; }

/* Joystick Elements */
.joystick-float {
  position: fixed;
  width: 20vh; height: 20vh;
  margin-left: -10vh; margin-top: -10vh;
  pointer-events: none;
  display: none;
  z-index: 100;
}
.joystick-float.visible { display: block; }
.stick-outer {
  width: 100%; height: 100%; border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  border: 2px solid rgba(255, 255, 255, 0.3);
  position: relative; box-shadow: 0 0 15px rgba(0,0,0,0.5);
}
.stick-inner {
  width: 8vh; height: 8vh;
  background: rgba(43, 111, 255, 0.8);
  border-radius: 50%;
  position: absolute; top: 50%; left: 50%;
  margin-top: -4vh; margin-left: -4vh;
  box-shadow: 0 0 10px rgba(43, 111, 255, 0.5);
}

/* Device List */
.device-list-float {
  position: absolute; top: 8vh; left: 20vw;
  width: 30vw; max-height: 40vh;
  background: #222; border: 1px solid #444; z-index: 300;
}
.device-item { padding: 1.5vh; border-bottom: 1px solid #333; font-size: 1.8vh; }

/* Logs */
.log-overlay {
  position: fixed; top: 26vh; right: 2vw;
  width: 40vw; height: 48vh;
  background: rgba(0,0,0,0.85); border: 1px solid #333;
  z-index: 200; display: flex; flex-direction: column;
  backdrop-filter: blur(10px);
}
.log-header { height: 4vh; background: #333; display: flex; justify-content: space-between; align-items: center; padding: 0 1vh; font-size: 1.6vh; }
.close-log { font-size: 2.5vh; cursor: pointer; color: #fff; padding: 0 1vh; }
.log-scroll { flex: 1; padding: 1vh; }
.log-item { font-family: monospace; font-size: 1.4vh; margin-bottom: 0.5vh; display: flex; gap: 1vh; }
.log-time { color: #888; }
.log-hex { color: #0f0; }

/* Font Scaling */
.mode-s { font-size: 90%; }
.mode-l { font-size: 110%; }
