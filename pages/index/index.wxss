/** index.wxss **/
page {
  background-color: #000000;
  color: #ffffff;
  height: 100vh;
  width: 100vw;
  overflow: hidden;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif; /* High aesthetic font */
}

.container {
  width: 100%;
  height: 100%;
  position: relative;
  overflow: hidden;
  background: #000;
  
  /* Defaults */
  --fs-title: 2.8vh;
  --fs-val: 2.2vh;
  --fs-btn: 2vh;
  --fs-log: 1.6vh;
}

/* --- Layer 1: Touch Zones --- */
.touch-zones {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  display: flex;
}

.zone {
  width: 50%;
  height: 100%;
  /* background: rgba(255, 0, 0, 0.1); Debugging tint */
}

/* --- Layer 2: Floating Joysticks --- */
.joystick-float {
  position: absolute;
  width: 20vh; /* Outer diameter */
  height: 20vh;
  z-index: 5;
  pointer-events: none; /* Let touches pass through to Layer 1 */
  opacity: 0;
  transform: scale(0.8);
  transition: opacity 0.1s, transform 0.1s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.joystick-float.visible {
  opacity: 1;
  transform: scale(1);
}

.joystick-base {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: radial-gradient(135deg, #3a3a3a 0%, #1a1a1a 100%);
  box-shadow: inset 2px 2px 5px rgba(0,0,0,0.8), inset -1px -1px 2px rgba(255,255,255,0.1), 0 5px 15px rgba(0,0,0,0.5);
  position: relative;
  border: 1px solid #333;
}

.joystick-stick {
  position: absolute;
  width: 8vh; /* Inner diameter */
  height: 8vh;
  top: 50%;
  left: 50%;
  margin-top: -4vh;
  margin-left: -4vh;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, #4facfe 0%, #00f2fe 100%);
  box-shadow: 0 4px 10px rgba(0, 100, 255, 0.4), inset 0 2px 5px rgba(255,255,255,0.4);
  transition: transform 0.05s, width 0.1s, height 0.1s, margin 0.1s;
}

.joystick-stick.active {
  background: radial-gradient(circle at 30% 30%, #3080e0 0%, #00c0d0 100%); /* Darker when pressed */
  transform: scale(0.95); /* Slight shrink visual */
}


/* --- Layer 3: UI Layer --- */
.ui-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 10;
  pointer-events: none; /* Let background touches pass, interactive elements re-enable pointer-events */
}

.top-bar {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 8vh;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 1vh 2vw;
  box-sizing: border-box;
  background: linear-gradient(to bottom, rgba(0,0,0,0.8), transparent);
}

.status-text {
  font-size: var(--fs-title);
  color: #fff;
  font-weight: bold;
  text-shadow: 0 1px 2px rgba(0,0,0,0.5);
  pointer-events: auto;
}

.top-actions {
  display: flex;
  gap: 2vw;
  pointer-events: auto;
}

.icon-btn {
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  color: #fff;
  padding: 0.5vh 1.5vh;
  border-radius: 4px;
  font-size: var(--fs-btn);
  backdrop-filter: blur(5px);
}

.center-dock {
  position: absolute;
  bottom: 5vh;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 4vw;
  pointer-events: auto;
}

.action-btn {
  width: 8vh;
  height: 8vh;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-btn);
  font-weight: bold;
  color: #fff;
  transition: all 0.1s;
  box-shadow: 0 4px 8px rgba(0,0,0,0.5), inset 0 1px 1px rgba(255,255,255,0.3);
  text-shadow: 0 1px 1px rgba(0,0,0,0.5);
}

.action-btn:active, .action-btn.active {
  transform: translateY(2px) scale(0.95);
  box-shadow: 0 1px 2px rgba(0,0,0,0.5);
  filter: brightness(0.9);
}

.action-btn.red { background: linear-gradient(135deg, #ff6b6b, #ff4444); border: 2px solid #800; }
.action-btn.blue { background: linear-gradient(135deg, #4facfe, #00f2fe); border: 2px solid #004080; }
.action-btn.green { background: linear-gradient(135deg, #43e97b, #38f9d7); border: 2px solid #006030; }
.action-btn.yellow { background: linear-gradient(135deg, #fddb92, #d1fdff); border: 2px solid #806000; color: #333; }
/* Fix yellow gradient */
.action-btn.yellow { background: linear-gradient(135deg, #ffeb3b, #fbc02d); color: #000; }


/* --- Layer 4: Panels --- */
.log-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  z-index: 20;
  display: none;
  justify-content: flex-end; /* Align right */
  pointer-events: auto;
}
.log-overlay.show { display: flex; }

.log-panel {
  width: 40%;
  height: 100%;
  background: rgba(0,0,0,0.9);
  border-left: 1px solid #333;
  display: flex;
  flex-direction: column;
  padding: 2vh;
  box-sizing: border-box;
}

.log-header {
  display: flex;
  justify-content: space-between;
  color: #fff;
  font-size: var(--fs-btn);
  margin-bottom: 2vh;
  border-bottom: 1px solid #444;
  padding-bottom: 1vh;
}

.log-actions {
  display: flex;
  gap: 2vw;
}

.close { color: #888; }

.log-scroll {
  flex: 1;
  height: 0;
  overflow-y: auto;
}

.log-item {
  font-family: "Courier New", monospace;
  font-size: var(--fs-log);
  color: #00ff00;
  margin-bottom: 2px;
  white-space: nowrap;
}

/* Modal Reuse */
.modal-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.8);
  z-index: 30;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
}

.modal-content {
  width: 50vw;
  background: #1a1a1a;
  border: 1px solid #444;
  border-radius: 8px;
  padding: 3vh;
}

.modal-header {
  text-align: center;
  color: #fff;
  font-size: var(--fs-title);
  margin-bottom: 2vh;
}

.setting-group {
    background: #222;
    padding: 1vh;
    border-radius: 4px;
    margin-bottom: 2vh;
}

.setting-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: #fff;
    font-size: var(--fs-btn);
    margin-bottom: 1vh;
}

.device-list-mini {
    max-height: 15vh;
    overflow-y: auto;
    background: #000;
    margin: 1vh 0;
}

.mini-device {
    color: #00ff00;
    font-size: var(--fs-log);
    padding: 0.5vh;
    border-bottom: 1px solid #333;
}

.font-size-controls {
    display: flex;
    gap: 1vw;
    margin-top: 1vh;
}

.font-btn {
    flex: 1;
    text-align: center;
    padding: 1vh 0;
    background: #333;
    color: #fff;
    border-radius: 4px;
    font-size: var(--fs-btn);
}
.font-btn.active {
    background: #2b6fff;
}
