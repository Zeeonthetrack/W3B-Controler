/* index.wxss */
.container {
  padding: 30rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.status {
  text-align: center;
  font-size: 32rpx;
  color: #333;
  margin-bottom: 30rpx;
  font-weight: bold;
}

.search-area {
  margin-bottom: 30rpx;
}

.search-btn {
  width: 100%;
  background-color: #07c160;
  color: white;
  border-radius: 10rpx;
}

.search-btn[disabled] {
  background-color: #ccc;
}

.device-list {
  margin-bottom: 40rpx;
}

.list-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.device-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
  background-color: white;
  border-radius: 10rpx;
  margin-bottom: 10rpx;
  font-size: 28rpx;
}

.remote-area {
  margin-top: 60rpx;
}

.btn-row {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  margin-bottom: 30rpx;
}

.control-btn {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background-color: #07c160;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.stop-btn {
  background-color: #ff4d4f;
}

.disconnect-btn {
  width: 100%;
  background-color: #ff4d4f;
  color: white;
  border-radius: 10rpx;
  margin-top: 60rpx;
}